{
  "name": "shipwrkrs",
  "private": true,
  "version": "0.1.0",
  "type": "module",
  "scripts": {
    "dev": "concurrently \"bunx wrangler dev --port 8788\" \"bunx vite\" --names \"api,vite\" --prefix-colors \"cyan,green\"",
    "dev:frontend": "VITE_FRONTEND_ONLY=true bunx vite",
    "dev:api": "bunx wrangler dev",
    "build": "bunx vite build",
    "preview": "bunx vite preview",
    "check": "bunx vue-tsc --noEmit",
    "deploy": "bun run build && bunx wrangler deploy",
    "db:migrate": "bunx wrangler d1 migrations apply shipwrkrs-db --local"
  },
  "dependencies": {
    "@codemirror/lang-javascript": "^6.2.2",
    "@codemirror/state": "^6.5.2",
    "@codemirror/theme-one-dark": "^6.1.3",
    "@codemirror/view": "^6.38.6",
    "@pierre/diffs": "^1.1.15",
    "@tailwindcss/vite": "^4.2.2",
    "@vueuse/core": "^14.2.1",
    "class-variance-authority": "^0.7.1",
    "clsx": "^2.1.1",
    "codemirror": "^6.0.2",
    "hono": "^4.12.15",
    "lucide-vue-next": "^1.0.0",
    "reka-ui": "^2.9.5",
    "tailwind-merge": "^3.5.0",
    "tailwindcss": "^4.2.2",
    "vue": "^3.5.13",
    "vue-router": "^4.5.0"
  },
  "devDependencies": {
    "@types/node": "^25.6.0",
    "@vitejs/plugin-vue": "^6.0.0",
    "concurrently": "^9.2.1",
    "typescript": "^5.8.3",
    "vite": "^7.0.0",
    "vue-tsc": "^2.2.8"
  }
}
